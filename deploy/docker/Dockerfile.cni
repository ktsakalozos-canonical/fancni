# Stage 1: Build the CNI binary
FROM golang:1.22-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY cmd/ cmd/
COPY internal/ internal/

RUN go build -o /fancni ./cmd/fancni/

# Stage 2: Install image
FROM busybox:1.36

COPY --from=builder /fancni /fancni
COPY deploy/scripts/install-cni.sh /install-cni.sh
RUN chmod +x /install-cni.sh

ENTRYPOINT ["/install-cni.sh"]
